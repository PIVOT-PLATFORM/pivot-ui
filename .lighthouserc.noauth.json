{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:4200/auth/login",
        "http://localhost:4200/auth/register",
        "http://localhost:4200/auth/forgot-password",
        "http://localhost:4200/auth/resend-verification",
        "http://localhost:4200/legal/mentions-legales",
        "http://localhost:4200/legal/confidentialite",
        "http://localhost:4200/legal/cgu"
      ],
      "numberOfRuns": 1,
      "puppeteerLaunchOptions": {
        "args": ["--no-sandbox", "--disable-dev-shm-usage"]
      }
    },
    "assert": {
      "assertMatrix": [
        {
          "matchingUrlPattern": ".*",
          "assertions": {
            "categories:accessibility": ["error", { "minScore": 0.6 }],
            "categories:performance": ["error", { "minScore": 0.6 }]
          }
        }
      ]
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
