{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "frontend": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": ["src/styles.scss"],
            "stylePreprocessorOptions": {
              "includePaths": ["projects/design-system/src/scss"]
            },
            "allowedCommonJsDependencies": ["@stomp/stompjs", "jszip"]
          },
          "configurations": {
            "production": {
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true,
                  "inlineCritical": false
                },
                "fonts": true
              },
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "12kB"
                }
              ],
              "outputHashing": "all",
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts"
                }
              ]
            },
            "ci": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "12kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            },
            "test": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "externalDependencies": ["@pivot-platform/collaboratif-ui"]
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "frontend:build:production"
            },
            "development": {
              "buildTarget": "frontend:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "tsconfig.spec.json",
            "runner": "vitest",
            "buildTarget": "frontend:build:test",
            "runnerConfig": "vitest.unit-test-runner.config.ts",
            "coverageReporters": ["lcov", "text", "html"],
            "setupFiles": ["src/test-setup-vitest.ts"]
          }
        }
      }
    },
    "agilite-ui": {
      "projectType": "library",
      "root": "projects/agilite-ui",
      "sourceRoot": "projects/agilite-ui/src",
      "prefix": "piv-agilite",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/agilite-ui/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/agilite-ui/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/agilite-ui/tsconfig.spec.json"
          }
        }
      }
    },
    "collaboratif-ui": {
      "projectType": "library",
      "root": "projects/collaboratif-ui",
      "sourceRoot": "projects/collaboratif-ui/src",
      "prefix": "piv-collab",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/collaboratif-ui/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/collaboratif-ui/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/collaboratif-ui/tsconfig.spec.json",
            "setupFiles": ["projects/collaboratif-ui/src/test-setup-vitest.ts"],
            "isolate": true,
            "coverageReporters": ["lcov", "text", "html"]
          }
        }
      }
    },
    "design-system": {
      "projectType": "library",
      "root": "projects/design-system",
      "sourceRoot": "projects/design-system/src",
      "prefix": "pivot-ds",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/design-system/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/design-system/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/design-system/tsconfig.spec.json"
          }
        }
      }
    }
  }
}
