# GitHub Packages — @pivot-platform scoped packages require authentication, both to publish
# this repo's own @pivot-platform/ui-core (EN17.3) and, since EN17.10, to install
# @pivot-platform/collaboratif-ui as a real dependency.
# In CI, NODE_AUTH_TOKEN is set automatically by actions/setup-node with registry-url.
# Locally: export NODE_AUTH_TOKEN=<your GitHub PAT with read:packages scope>
@pivot-platform:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
